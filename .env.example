# Embedding-Modell (sentence-transformers)
# Für mehrsprachige/ deutsche Texte empfohlen:
MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
# Alternativ (kleiner, englisch-lastig): all-MiniLM-L6-v2

# Schwellwert für Ähnlichkeit (0..1); bei Werten darunter wird der Vorschlag als unsicher markiert
SIMILARITY_THRESHOLD=0.6

# Maximale Anzahl ähnlicher Dokumente, die für den Vorschlag berücksichtigt werden
TOP_K=5

# ChromaDB Sammlungsname
COLLECTION_NAME=documents

# Intervall für Inbox-Scan (Sekunden)
SCAN_INTERVAL=5

# Pfade (werden im Container überschrieben, hier nur zur Dokumentation)
INBOX_PATH=/inbox
REPO_PATH=/repo